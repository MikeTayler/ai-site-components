{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-site.dev/schemas/components/TextContent.schema.json",
  "title": "TextContent",
  "type": "object",
  "additionalProperties": false,
  "required": ["variant", "content"],
  "properties": {
    "variant": {
      "type": "string",
      "enum": ["single-column", "two-column", "with-sidebar"]
    },
    "content": {
      "type": "object",
      "additionalProperties": false,
      "required": ["paragraphs"],
      "properties": {
        "heading": { "type": "string" },
        "paragraphs": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "asideTitle": { "type": "string" },
        "asideParagraphs": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "settings": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "maxWidth": { "type": "string", "enum": ["narrow", "wide", "full"] }
      }
    },
    "className": { "type": "string" },
    "contentPathPrefix": { "type": "string" }
  }
}
