{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-site.dev/schemas/components/TeamGrid.schema.json",
  "title": "TeamGrid",
  "type": "object",
  "additionalProperties": false,
  "required": ["variant", "content"],
  "properties": {
    "variant": { "type": "string", "enum": ["cards", "headshots", "detailed"] },
    "content": {
      "type": "object",
      "additionalProperties": false,
      "required": ["members"],
      "properties": {
        "heading": { "type": "string" },
        "members": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name"],
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "role": { "type": "string" },
              "bio": { "type": "string" }
            }
          }
        }
      }
    },
    "settings": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "maxWidth": { "type": "string", "enum": ["narrow", "wide", "full"] }
      }
    },
    "className": { "type": "string" },
    "contentPathPrefix": { "type": "string" }
  }
}
