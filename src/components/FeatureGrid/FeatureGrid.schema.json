{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-site.dev/schemas/components/FeatureGrid.schema.json",
  "title": "FeatureGrid",
  "type": "object",
  "additionalProperties": false,
  "required": ["variant", "content"],
  "properties": {
    "variant": {
      "type": "string",
      "enum": ["three-column", "two-column-images", "alternating"]
    },
    "content": {
      "type": "object",
      "additionalProperties": false,
      "required": ["heading", "items"],
      "properties": {
        "heading": { "type": "string", "minLength": 1 },
        "items": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["title"],
            "properties": {
              "title": { "type": "string", "minLength": 1 },
              "description": { "type": "string" }
            }
          }
        }
      }
    },
    "settings": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "maxWidth": { "type": "string", "enum": ["narrow", "wide", "full"] }
      }
    },
    "className": { "type": "string" },
    "contentPathPrefix": { "type": "string" }
  }
}
