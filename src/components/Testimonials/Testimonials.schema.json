{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-site.dev/schemas/components/Testimonials.schema.json",
  "title": "Testimonials",
  "type": "object",
  "additionalProperties": false,
  "required": ["variant", "content"],
  "properties": {
    "variant": { "type": "string", "enum": ["cards", "featured", "carousel"] },
    "content": {
      "type": "object",
      "additionalProperties": false,
      "required": ["items"],
      "properties": {
        "heading": { "type": "string" },
        "items": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["quote", "author"],
            "properties": {
              "quote": { "type": "string", "minLength": 1 },
              "author": { "type": "string", "minLength": 1 },
              "role": { "type": "string" }
            }
          }
        }
      }
    },
    "settings": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "maxWidth": { "type": "string", "enum": ["narrow", "wide", "full"] }
      }
    },
    "className": { "type": "string" },
    "contentPathPrefix": { "type": "string" }
  }
}
