{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-site.dev/schemas/components/PricingTable.schema.json",
  "title": "PricingTable",
  "type": "object",
  "additionalProperties": false,
  "required": ["variant", "content"],
  "properties": {
    "variant": { "type": "string", "enum": ["tier-cards", "comparison", "simple"] },
    "content": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tiers"],
      "properties": {
        "heading": { "type": "string" },
        "tiers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "price", "features"],
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "price": { "type": "string", "minLength": 1 },
              "currency": { "type": "string" },
              "features": {
                "type": "array",
                "items": { "type": "string" }
              },
              "cta": {
                "type": "object",
                "additionalProperties": false,
                "required": ["label", "href"],
                "properties": {
                  "label": { "type": "string", "minLength": 1 },
                  "href": { "type": "string", "minLength": 1 }
                }
              }
            }
          }
        }
      }
    },
    "settings": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "maxWidth": { "type": "string", "enum": ["narrow", "wide", "full"] }
      }
    },
    "className": { "type": "string" },
    "contentPathPrefix": { "type": "string" }
  }
}
